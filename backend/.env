MONGO_URI="mongodb+srv://admin:root@cluster59.vjp7w.mongodb.net/?retryWrites=true&w=majority&appName=Cluster59"
MONGO_DB_NAME="aitutordb"

# --- JWT Configuration ---
JWT_SECRET_KEY="jyvWXt-jZtpyaSvX6kZrx6jDqY8IYeimqp0fdnthMbQNBain2byuJZnxHGWZocsVt4mIOLnMq8Uz8XWjZ90Mgg" # CHANGE THIS!
