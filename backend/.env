# --- RAG Configuration ---
# RAG_CHUNK_K=5               # Max unique chunks sent to LLM for synthesis
# RAG_SEARCH_K_PER_QUERY=3    # Chunks retrieved per sub-query before deduplication
# MULTI_QUERY_COUNT=3         # Number of sub-queries generated (0 to disable)

# --- Analysis Configuration ---
# ANALYSIS_MAX_CONTEXT_LENGTH=8000 # Max characters of document text sent for analysis
NOUGAT_MODEL_TAG="0.1.0-small"
# Option 2: Specify the full path to a PRE-DOWNLOADED Nougat model directory.
# If this is set, NOUGAT_MODEL_TAG might be ignored by the script for loading, but good to keep consistent.
# Example: NOUGAT_CHECKPOINT_PATH="C:/Users/sathw/.cache/torch/hub/nougat-0.1.0-small"
# Example: NOUGAT_CHECKPOINT_PATH="/path/to/your/cloned/nougat/checkpoints/nougat-small"
NOUGAT_CHECKPOINT_PATH="C:/Users/sathw/.cache/torch/hub/nougat-0.1.0-small" # <--- SET THIS TO THE CORRECT PATH of the model the CLI used
# NOUGAT_CHECKPOINT_PATH="" # Set to empty if you want to rely on NOUGAT_MODEL_TAG for download
# --- Logging Configuration ---
# Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Set to DEBUG for detailed troubleshooting.
LOGGING_LEVEL=INFO
# LOGGING_LEVEL=DEBUG
